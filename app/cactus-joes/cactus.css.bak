/* ============================================================
   CACTUS JOE'S — Global Styles
   thevoiceofcash.com/cactus-joes
   ============================================================ */

@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600&display=swap');

:root {
  --bg-dark: #0D0D0D;
  --bg-warm: #1A1207;
  --bg-predawn-a: #1B1030;
  --bg-predawn-b: #8B5E6B;
  --bg-daylight-a: #D4A843;
  --bg-daylight-b: #C4A97D;
  --text-primary: #F5E6C8;
  --text-secondary: #C4A97D;
  --accent: #D4A843;
  --accent-secondary: #E07C3E;
  --night-blue: #1B2838;
  --card-bg: rgba(20, 18, 12, 0.85);
  --card-border: rgba(196, 169, 125, 0.2);
  --font-serif: 'Playfair Display', Georgia, 'Times New Roman', serif;
  --font-sans: 'Inter', 'DM Sans', system-ui, -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', 'IBM Plex Mono', 'Courier New', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  scroll-behavior: smooth;
  font-size: 18px;
}

body {
  font-family: var(--font-sans);
  background: linear-gradient(160deg, var(--bg-dark), var(--bg-warm));
  color: var(--text-primary);
  line-height: 1.7;
  overflow-x: hidden;
}

/* Skip link */
.skip-link {
  position: absolute;
  top: -40px;
  left: 0;
  background: var(--accent);
  color: #000;
  padding: 8px 16px;
  z-index: 1000;
  font-weight: 600;
  transition: top 0.2s;
}
.skip-link:focus { top: 0; }

/* Scroll progress bar */
.scroll-progress {
  position: fixed;
  top: 0;
  right: 0;
  width: 3px;
  height: 100vh;
  background: rgba(212, 168, 67, 0.15);
  z-index: 999;
}
.scroll-progress-fill {
  width: 100%;
  height: 100%;
  background: var(--accent);
  transform: scaleY(0);
  transform-origin: top;
  transition: transform 0.1s linear;
  will-change: transform;
}

/* ============================================================
   PASSWORD GATE
   ============================================================ */
.pw-gate {
  position: fixed;
  inset: 0;
  background: linear-gradient(160deg, var(--bg-predawn-a), var(--bg-warm));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  gap: 1.5rem;
}
.pw-gate h1 {
  font-family: var(--font-serif);
  font-size: clamp(1.25rem, 3vw, 2rem);
  color: var(--text-primary);
  text-align: center;
  letter-spacing: 0.04em;
}
.pw-gate p {
  color: var(--text-secondary);
  font-size: 0.9rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.pw-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  align-items: center;
  width: 100%;
  max-width: 320px;
}
.pw-input {
  width: 100%;
  padding: 0.75rem 1rem;
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  color: var(--text-primary);
  font-family: var(--font-sans);
  font-size: 1rem;
  border-radius: 4px;
  text-align: center;
  letter-spacing: 0.2em;
  outline: none;
  transition: border-color 0.2s;
}
.pw-input:focus { border-color: var(--accent); outline: 2px solid var(--accent); outline-offset: 2px; }
.pw-btn {
  width: 100%;
  padding: 0.75rem 2rem;
  background: var(--accent);
  color: #000;
  font-family: var(--font-sans);
  font-weight: 700;
  font-size: 0.9rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.pw-btn:hover { background: #e6b84a; transform: translateY(-2px); }
.pw-btn:focus { outline: 2px solid var(--accent); outline-offset: 2px; }
.pw-error {
  color: var(--accent-secondary);
  font-size: 0.85rem;
  text-align: center;
  min-height: 1.2em;
}
.pw-gate.hidden { display: none; }

/* ============================================================
   SCROLL REVEAL — base state
   ============================================================ */
.reveal {
  opacity: 0;
  transform: translate3d(0, 20px, 0);
  transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  will-change: opacity, transform;
}
.reveal.visible {
  opacity: 1;
  transform: translate3d(0, 0, 0);
}
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }
.reveal-delay-4 { transition-delay: 0.4s; }
.reveal-delay-5 { transition-delay: 0.5s; }
.reveal-delay-6 { transition-delay: 0.6s; }
.reveal-delay-7 { transition-delay: 0.7s; }

@media (prefers-reduced-motion: reduce) {
  .reveal {
    opacity: 1;
    transform: none;
    transition: opacity 0.2s;
  }
  * { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; }
}

/* ============================================================
   SCENE SHARED
   ============================================================ */
.scene {
  position: relative;
  width: 100%;
  padding: 6rem 2rem;
  overflow: hidden;
}
.scene-inner {
  max-width: 900px;
  margin: 0 auto;
}
.scene-tag {
  font-size: 0.75rem;
  color: var(--text-secondary);
  letter-spacing: 0.12em;
  text-transform: uppercase;
}
.serif { font-family: var(--font-serif); }
.accent-text { color: var(--accent); }
.secondary-text { color: var(--text-secondary); }
.mono { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }

h1, h2, h3 { font-family: var(--font-serif); font-weight: 700; line-height: 1.2; color: var(--text-primary); }

.section-header {
  font-family: var(--font-serif);
  font-size: clamp(1.75rem, 4vw, 3rem);
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 2rem;
  color: var(--text-primary);
}
.section-subheader {
  font-size: clamp(1rem, 2vw, 1.25rem);
  color: var(--text-secondary);
  margin-bottom: 1.5rem;
}
.callout-text {
  font-family: var(--font-serif);
  font-size: clamp(1.1rem, 2.5vw, 1.6rem);
  font-weight: 700;
  line-height: 1.4;
  color: var(--text-primary);
  text-align: center;
  margin: 3rem auto;
  max-width: 700px;
}
.body-text {
  font-size: clamp(1rem, 1.5vw, 1.125rem);
  color: var(--text-primary);
  line-height: 1.8;
  max-width: 700px;
}
.italic-muted {
  font-style: italic;
  color: var(--text-secondary);
  font-size: clamp(0.9rem, 1.4vw, 1rem);
  max-width: 680px;
  line-height: 1.7;
}

/* Card */
.card {
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 6px;
  padding: 2rem;
  transition: transform 0.3s ease-out, box-shadow 0.3s ease-out;
}
.card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 32px rgba(212, 168, 67, 0.12);
}
.card h3 {
  font-family: var(--font-serif);
  font-size: 1.1rem;
  margin-bottom: 0.75rem;
  color: var(--accent);
}

/* Focus indicator */
:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

/* ============================================================
   SCENE 1 — COLD OPEN
   ============================================================ */
.scene-1 {
  min-height: 200vh;
  background: linear-gradient(160deg, var(--bg-predawn-a), var(--bg-predawn-b));
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding: 0;
  position: relative;
  overflow: hidden;
}
.scene-1-bg-dawn {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, var(--bg-predawn-a), var(--bg-predawn-b));
  z-index: 0;
}
.scene-1-bg-day {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, var(--bg-daylight-a), var(--bg-daylight-b));
  opacity: 0;
  z-index: 0;
  transition: opacity 0.5s ease;
}
.scene-1-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 15vh 2rem 0;
  max-width: 900px;
  margin: 0 auto;
  width: 100%;
}
.scene-1-line {
  font-size: clamp(1.25rem, 2.5vw, 1.75rem);
  color: var(--text-primary);
  padding: 2vh 0;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease-out, transform 0.6s ease-out;
}
.scene-1-line.visible { opacity: 1; transform: translateY(0); }
.scene-1-line.turn { font-weight: 600; }
.scene-1-line.zinger {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  text-align: center;
  padding: 6vh 0;
  color: var(--text-primary);
}
.scene-1-beat { height: 30vh; }
.scene-1-beat-sm { height: 20vh; }
.scene-1-tag {
  font-size: 0.75rem;
  color: var(--text-secondary);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-align: center;
  padding: 4vh 0 8vh;
}

/* Desert silhouette SVG */
.desert-silhouette {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  z-index: 1;
  pointer-events: none;
  opacity: 0.6;
}

/* ============================================================
   SCENE 2 — WHO'S IN THE ROOM
   ============================================================ */
.scene-2 {
  min-height: 150vh;
  background: linear-gradient(160deg, var(--bg-warm), var(--bg-dark));
  padding: 8rem 2rem;
}
.two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  margin: 3rem 0;
  transition: transform 0.5s ease-in-out;
}
.two-col.merged .panel-left { transform: translateX(2.5%); }
.two-col.merged .panel-right { transform: translateX(-2.5%); }
.panel-left { transition: transform 0.5s ease-in-out; }
.panel-right { transition: transform 0.5s ease-in-out; }
.card-warm { border-color: rgba(212, 168, 67, 0.25); }
.card-cool { border-color: rgba(27, 40, 56, 0.4); }
.panel-label {
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1rem;
  font-weight: 600;
}
.panel-item {
  color: var(--text-secondary);
  font-size: clamp(0.9rem, 1.3vw, 1rem);
  padding: 0.4rem 0;
  border-bottom: 1px solid rgba(196, 169, 125, 0.1);
}
.panel-item:last-child { border-bottom: none; }
.scene-2-center {
  text-align: center;
  margin-top: 2rem;
}

@media (max-width: 768px) {
  .two-col {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .two-col.merged .panel-left,
  .two-col.merged .panel-right { transform: none; }
}

/* ============================================================
   SCENE 3 — THE PROBLEM
   ============================================================ */
.scene-3 {
  min-height: 200vh;
  background: linear-gradient(160deg, var(--bg-dark), #0a0805);
  padding: 8rem 2rem;
  position: relative;
}
.scene-3::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.4) 100%);
  pointer-events: none;
  z-index: 0;
}
.scene-3 .scene-inner { position: relative; z-index: 1; }

.stat-line {
  border-left: 3px solid var(--accent);
  padding: 0.6rem 0 0.6rem 1rem;
  margin: 0.75rem 0;
  font-size: clamp(1rem, 1.5vw, 1.1rem);
  color: var(--text-primary);
  font-weight: 400;
}

/* Progress bar */
.revenue-bar-wrap {
  margin: 3rem 0;
}
.revenue-bar-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-secondary);
  margin-bottom: 0.5rem;
}
.revenue-bar {
  width: 100%;
  height: 12px;
  border-radius: 6px;
  overflow: hidden;
  background: rgba(255,255,255,0.04);
  display: flex;
}
.revenue-bar-captured {
  width: 17%;
  height: 100%;
  background: var(--accent);
  border-radius: 6px 0 0 6px;
  flex-shrink: 0;
}
.revenue-bar-lost {
  flex: 1;
  height: 100%;
  background: var(--accent-secondary);
  opacity: 0.35;
  border-radius: 0 6px 6px 0;
  animation: pulseBar 3s ease-in-out infinite;
}
.revenue-bar-lost.stat-1 { animation-name: pulseBar1; }
.revenue-bar-lost.stat-2 { animation-name: pulseBar2; }
.revenue-bar-lost.stat-3 { animation-name: pulseBar3; }
.revenue-bar-lost.stat-4 { animation-name: pulseBar4; }
.revenue-bar-lost.stat-5 { animation-name: pulseBar5; }
.revenue-bar-lost.stat-6 { animation-name: pulseBar6; }
.revenue-bar-lost.stat-7 { animation-name: pulseBar7; }

@keyframes pulseBar  { 0%,100%{opacity:0.30} 50%{opacity:0.50} }
@keyframes pulseBar1 { 0%,100%{opacity:0.30} 50%{opacity:0.52} }
@keyframes pulseBar2 { 0%,100%{opacity:0.30} 50%{opacity:0.54} }
@keyframes pulseBar3 { 0%,100%{opacity:0.30} 50%{opacity:0.56} }
@keyframes pulseBar4 { 0%,100%{opacity:0.30} 50%{opacity:0.58} }
@keyframes pulseBar5 { 0%,100%{opacity:0.30} 50%{opacity:0.60} }
@keyframes pulseBar6 { 0%,100%{opacity:0.30} 50%{opacity:0.63} }
@keyframes pulseBar7 { 0%,100%{opacity:0.30} 50%{opacity:0.66} }

@media (prefers-reduced-motion: reduce) {
  .revenue-bar-lost, .revenue-bar-lost[class*="stat-"] {
    animation: none;
    opacity: 0.45;
  }
}
